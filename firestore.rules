rules_version = '2';

// Eden 54 — Firestore Security Rules
//
// Auth situation (post Phase 1+2 migration):
//   All portal staff  → Firebase Auth session (email = posUsername@eden54.pos)
//   POS terminal      → Firebase Auth (same Firebase project, same session)
//   Public forms      → unauthenticated (apartment bookings only)
//
// Role lookup via staffByAuth/{uid}, written on every login by portal/index.html.
//   Fields: { staffId, accessLevel, department, active }
//   isManager() and isHR() each call get() on this doc (1 extra read per evaluation).
//
// To deploy: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function authData() {
      return get(/databases/$(database)/documents/staffByAuth/$(request.auth.uid)).data;
    }

    function isManager() {
      let r = authData().accessLevel;
      return r == 'ceo' || r == 'superadmin' || r == 'manager'
          || r.matches('.*(ceo|superadmin|manager).*');
    }

    function isHR() {
      let d = authData();
      return d.accessLevel == 'hr'
          || d.get('department', '') == 'hr'
          || d.get('department', '').matches('.*human.resource.*');
    }

    function isManagerOrHR() {
      return isManager() || isHR();
    }

    function validAmount(field) {
      return !(field in request.resource.data)
          || (request.resource.data[field] is number
              && request.resource.data[field] >= 0);
    }

    function validSaleShape() {
      let d = request.resource.data;
      return d.staffId is string && d.staffId.size() > 0
          && d.date is string && d.date.size() == 10
          && validAmount('amount')
          && validAmount('totalSales')
          && validAmount('cashSales')
          && validAmount('transferSales')
          && validAmount('posSales');
    }

    function validTabShape() {
      let d = request.resource.data;
      return d.customerName is string && d.customerName.size() > 0
          && d.status in ['open', 'awaiting', 'awaiting-pos', 'paid'];
    }

    // ── staffByAuth ───────────────────────────────────────────────────────────
    // Written on every login — each user may only write their own doc.
    // Managers can read any doc (for future admin tooling).
    match /staffByAuth/{uid} {
      allow read:  if isAuth() && (request.auth.uid == uid || isManager());
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ── Staff profiles ────────────────────────────────────────────────────────
    // Public read: the login page loads the staff list unauthenticated (photo/name picker).
    // Writes are restricted to managers/HR.
    match /staff/{doc} {
      allow read:           if true;
      allow create, update: if isAuth() && isManagerOrHR();
      allow delete:         if isAuth() && isManager();
    }

    // ── Sales ─────────────────────────────────────────────────────────────────
    // Any authenticated staff can read and log a sale (POS + manual entry).
    // Only managers can correct or void a sale record.
    match /sales/{doc} {
      allow read:           if isAuth();
      allow create:         if isAuth() && validSaleShape();
      allow update, delete: if isAuth() && isManager();
    }

    // ── Table Tabs ────────────────────────────────────────────────────────────
    // Lounge/bar staff create and update tabs throughout service.
    // Only managers can delete a tab (voiding a completed table).
    match /tabs/{doc} {
      allow read:   if isAuth();
      allow create: if isAuth() && validTabShape();
      allow update: if isAuth();
      allow delete: if isAuth() && isManager();
    }

    // ── Menu Items ────────────────────────────────────────────────────────────
    // All authenticated staff can read (POS loads the menu on startup).
    // Only managers can add, edit, or remove items.
    match /menuItems/{doc} {
      allow read:  if isAuth();
      allow write: if isAuth() && isManager();
    }

    // ── Barbing Reports ───────────────────────────────────────────────────────
    // Salon staff report through POS only — barbing_reports is manager-submitted.
    match /barbing_reports/{doc} {
      allow read:           if isAuth();
      allow create:         if isAuth() && isManager()
                            && request.resource.data.staffId is string
                            && request.resource.data.date    is string;
      allow update, delete: if isAuth() && isManager();
    }

    // ── FCM / Push Tokens ─────────────────────────────────────────────────────
    match /fcmTokens/{token} {
      allow read, write: if isAuth();
    }

    // ── Audit Log (append-only) ───────────────────────────────────────────────
    // Any authenticated staff can append a record; nobody can edit or delete.
    // Only managers/HR can read (contains sensitive action trail).
    match /auditLog/{doc} {
      allow read:           if isAuth() && isManagerOrHR();
      allow create:         if isAuth();
      allow update, delete: if false;
    }

    // ── Apartment Bookings ────────────────────────────────────────────────────
    // Public creates — guests submit the booking form without a portal login.
    // Portal staff (authenticated) manage status, confirmations, and deletions.
    match /apartmentBookings/{doc} {
      allow create: if request.resource.data.firstName is string
                    && request.resource.data.lastName  is string
                    && request.resource.data.phone     is string;
      allow read, update, delete: if isAuth();
    }

    // ── Everything else ───────────────────────────────────────────────────────
    // Covers: expenses, attendance, clockings, payroll, incidents, pool_reports,
    // bar_reports, kitchen_reports, notices/updates, background checks, etc.
    // All require a valid Firebase Auth session at minimum.
    // Add explicit rules above as those collections need tighter per-role control.
    match /{document=**} {
      allow read, write: if isAuth();
    }
  }
}
